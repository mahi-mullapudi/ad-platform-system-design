# ── Ad-Click Service ──────────────────────────────────────────
# R2DBC (reactive database access)
SPRING_R2DBC_URL=r2dbc:postgresql://localhost:5432/ads_platform
SPRING_R2DBC_USERNAME=ads_user
SPRING_R2DBC_PASSWORD=ads_password

# Flyway (schema migrations via JDBC)
SPRING_FLYWAY_URL=jdbc:postgresql://localhost:5432/ads_platform
SPRING_FLYWAY_USER=ads_user
SPRING_FLYWAY_PASSWORD=ads_password

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# SASL/SSL for Azure Event Hubs (leave empty for local Kafka)
SPRING_KAFKA_PROPERTIES_SECURITY_PROTOCOL=PLAINTEXT
SPRING_KAFKA_PROPERTIES_SASL_MECHANISM=
SPRING_KAFKA_PROPERTIES_SASL_JAAS_CONFIG=

# ── Ad-Click Processor (Flink) ───────────────────────────────
FLINK_PARALLELISM=4
FLINK_CHECKPOINT_DIR=file:///tmp/flink-checkpoints
FLINK_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
FLINK_KAFKA_SOURCE_TOPIC=ad-click-events
FLINK_KAFKA_SINK_TOPIC=ad-click-aggregations
FLINK_KAFKA_CONSUMER_GROUP=ad-click-processor

# SASL/SSL for Azure Event Hubs (leave empty for local Kafka)
FLINK_KAFKA_SECURITY_PROTOCOL=PLAINTEXT
FLINK_KAFKA_SASL_MECHANISM=
FLINK_KAFKA_SASL_JAAS_CONFIG=

# ── Analytics Gateway ────────────────────────────────────────
BACKEND_URI=http://localhost:8081
ALLOWED_ORIGINS=http://localhost:3000
